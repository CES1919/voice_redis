{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASREvent",
  "description": "A 镜像写入 asr_events Stream 的 JSON 格式",
  "type": "object",
  "required": [
    "id",
    "timestamp",
    "text",
    "wav_path",
    "sample_rate",
    "offset_sec",
    "duration_sec",
    "segment_index",
    "asr_model"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^asr_\\d{8}_\\w+_\\d{6}$",
      "description": "唯一标识，格式 asr_YYYYMMDD_sessionId_NNNNNN"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 时间戳"
    },
    "text": {
      "type": "string",
      "description": "ASR 识别文本"
    },
    "wav_path": {
      "type": "string",
      "description": "音频文件路径"
    },
    "sample_rate": {
      "type": "integer",
      "description": "采样率 (Hz)"
    },
    "offset_sec": {
      "type": "number",
      "description": "片段起始偏移 (秒)"
    },
    "duration_sec": {
      "type": "number",
      "description": "片段时长 (秒)"
    },
    "segment_index": {
      "type": "integer",
      "description": "片段序号"
    },
    "asr_model": {
      "type": "string",
      "description": "ASR 模型路径"
    }
  },
  "additionalProperties": false
}
